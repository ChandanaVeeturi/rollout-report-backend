# SQLite (default, zero setup — file created automatically in backend/)
DATABASE_URL=sqlite:///./rollout_report.db

# Switch to PostgreSQL later:
# DATABASE_URL=postgresql://user:password@localhost:5432/rollout_report
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# Admin account (created on first run)
ADMIN_EMAIL=admin@rolloutreport.com
ADMIN_PASSWORD=changeme123

# Optional: S3-compatible storage
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=rollout-report

CORS_ORIGINS=http://localhost:5173
